                "description": {
                    "type": "string"
                },
                "ecosystem": {
                    "type": "string"
                },
                "homepage": {
                    "type": "string"
                },
                "latest_version": {
                    "type": "string"
                },
                "license": {
                    "type": "string"
                },
                "license_category": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "registry_url": {
                    "type": "string"
                },
