                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "server.PackageListResult": {
            "type": "object",
            "properties": {
                "cached_at": {
                    "type": "string"
                },
                "ecosystem": {
                    "type": "string"
                },
                "hits": {
                    "type": "integer"
                },
                "latest_version": {
                    "type": "string"
                },
                "license": {
                    "type": "string"
                },
                "license_category": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "size": {
                    "type": "integer"
                },
                "vuln_count": {
                    "type": "integer"
                }
